{
  "name": "woa-acp",
  "version": "0.2.0",
  "description": "WPS Office AI Agentspace + ACP adapter — connect Cursor CLI / Claude Code / Codex to WPS 数字员工",
  "license": "MIT",
  "type": "module",
  "bin": {
    "woa-acp": "dist/main.mjs"
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "wps-feedback-server.cjs"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "^0.26.0",
    "@agentclientprotocol/sdk": "^0.18.2",
    "@zed-industries/codex-acp": "^0.11.1",
    "cross-spawn": "^7.0.6",
    "ws": "^8.18.0"
  },
  "scripts": {
    "build": "tsdown",
    "login": "tsx main.ts login",
    "start": "tsx main.ts start -- agent acp",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tsdown": "^0.21.7",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0"
  }
}
